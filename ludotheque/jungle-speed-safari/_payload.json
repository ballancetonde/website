 :",[102,103,104,118,125,131,137],"ul",{},[59,105,106,107,110,111,114,115,35],{},"Une version encore plus ",[14,108,109],{},"délirante"," de ",[14,112,113],{},"Jungle Speed",", avec ",[14,116,117],{},"interactions immédiates et bruitages assurés",[59,119,120,121,124],{},"Des règles ",[14,122,123],{},"ultra simples",", accessibles dès les premières secondes.",[59,126,127,128,35],{},"Un jeu qui mélange ",[14,129,130],{},"réflexe, observation, et improvisation sonore",[59,132,133,136],{},[14,134,135],{},"Parfait pour les enfants comme pour les adultes",", en mode défouloir fun.",[59,138,139,140,143],{},"Un ",[14,141,142],{},"matériel coloré et solide",", prêt à résister à vos cris de panthère et vos bonds de gazelle.",{"title":145,"searchDepth":146,"depth":146,"links":147},"",2,[148,150],{"id":53,"depth":149,"text":54},3,{"id":99,"depth":149,"text":100},"Dans Jungle Speed Safari, oubliez la jungle urbaine : ici, c’est la vraie savane qui vous attend, avec ses animaux affamés, ses totems sauvages… et ses cris inoubliables. Un jeu d’observation, de réflexe et de folie douce, où il faudra attraper, taper, crier, imiter, et surtout… survivre au chaos.",true,"md","/ludotheque/jungle-speed-safari.jpg",{},null,"/ludotheque/jungle-speed-safari",15,{"min":146,"max":160},6,"[object Object]","ludotheque/Jungle-Speed-safari","https://www.youtube.com/watch?v=nattVfSTZ78","OlGbceYwcF0mDy7y0_mny3AHMf7nvg6x3E64W9qW854",1744555003275]