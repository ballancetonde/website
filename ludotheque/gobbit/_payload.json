[{"data":1,"prerenderedAt":170},["ShallowReactive",2],{"/ludotheque/gobbit":3},{"id":4,"title":5,"body":6,"description":156,"donation":157,"extension":158,"image":159,"meta":160,"navigation":161,"path":162,"play_time_mins":163,"players":164,"purchase_date":161,"seo":166,"stem":167,"video":168,"__hash__":169},"games/ludotheque/Gobbit.md","Gobbit",{"type":7,"value":8,"toc":149},"minimal",[9,17,48,63,68,95,108,112],[10,11,13],"h1",{"id":12},"gobbit-la-chaîne-alimentaire-na-jamais-été-aussi-rapide",[14,15,16],"strong",{},"Gobbit — La chaîne alimentaire n’a jamais été aussi rapide.",[18,19,20,21,23,24,27,28,31,32,35,36,39,40,43,44,47],"p",{},"Dans ",[14,22,5],{},", vos réflexes sont votre seule chance de survie ! Ici, ",[14,25,26],{},"les animaux s’affrontent sans pitié"," dans une chaîne alimentaire infernale : le ",[14,29,30],{},"caméléon mange la mouche",", le ",[14,33,34],{},"serpent mange le caméléon",", et ",[14,37,38],{},"l’aigle mange tout le monde","… sauf lui-même ! Un jeu ",[14,41,42],{},"frénétique, instinctif et impitoyable",", où ",[14,45,46],{},"la rapidité d’exécution"," est votre arme la plus tranchante.",[18,49,50,51,54,55,58,59,62],{},"Un jeu pour ",[14,52,53],{},"2 à 8 joueurs",", dès ",[14,56,57],{},"6 ans",", en ",[14,60,61],{},"10 minutes de pure tension animale",".",[64,65,67],"h3",{"id":66},"survie-réflexe-et-frappes-chirurgicales","Survie, réflexe, et frappes chirurgicales !",[69,70,71,78,88],"ol",{},[72,73,74,75,62],"li",{},"Chaque joueur a une ",[14,76,77],{},"pile de cartes face cachée",[72,79,80,81,84,85],{},"À votre tour, ",[14,82,83],{},"retournez une carte"," : si elle peut manger une autre… ",[14,86,87],{},"tapez vite dessus !",[72,89,90,91,94],{},"Mais attention : ",[14,92,93],{},"mal viser peut vous faire perdre vos cartes","… ou attirer les foudres d’un aigle !",[18,96,97,98,43,101,104,105,62],{},"⚡ Une mécanique ",[14,99,100],{},"simple mais ultra nerveuse",[14,102,103],{},"les erreurs coûtent cher","… et ",[14,106,107],{},"les revanches sont obligatoires",[64,109,111],{"id":110},"gobbit-cest-aussi","Gobbit, c’est aussi :",[113,114,115,122,129,135,142],"ul",{},[72,116,117,118,121],{},"Un jeu ",[14,119,120],{},"d’ambiance survitaminée",", parfait pour les familles comme les amis.",[72,123,124,125,128],{},"Une ",[14,126,127],{},"chaîne alimentaire intuitive",", facile à expliquer même aux plus jeunes.",[72,130,131,134],{},[14,132,133],{},"Une tension constante",", où chaque carte peut faire basculer la partie.",[72,136,137,138,141],{},"Un format ",[14,139,140],{},"poche et costaud",", parfait pour emporter partout.",[72,143,144,145,148],{},"Et un mode ",[14,146,147],{},"\"Évolution sauvage\""," pour les plus aguerris 🦅",{"title":150,"searchDepth":151,"depth":151,"links":152},"",2,[153,155],{"id":66,"depth":154,"text":67},3,{"id":110,"depth":154,"text":111},"Dans Gobbit, vos réflexes sont votre seule chance de survie ! Ici, les animaux s’affrontent sans pitié dans une chaîne alimentaire infernale : le caméléon mange la mouche, le serpent mange le caméléon, et l’aigle mange tout le monde… sauf lui-même ! Un jeu frénétique, instinctif et impitoyable, où la rapidité d’exécution est votre arme la plus tranchante.",true,"md","/ludotheque/gobbit.webp",{},null,"/ludotheque/gobbit",15,{"min":151,"max":165},8,"[object Object]","ludotheque/Gobbit","https://www.youtube.com/watch?v=yxd4wmyKWFs","lCEvjZSpBC0ZWE6vfhYQ5_9xmENgHcIY6_ZMSvKWcXg",1744590047424]