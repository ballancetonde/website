[{"data":1,"prerenderedAt":205},["ShallowReactive",2],{"/ludotheque/bang-le-jeu-de-des":3},{"id":4,"title":5,"body":6,"description":15,"donation":192,"extension":193,"image":194,"meta":195,"navigation":196,"path":197,"play_time_mins":198,"players":199,"purchase_date":196,"seo":201,"stem":202,"video":203,"__hash__":204},"games/ludotheque/bang-le-jeu-de-des.md","Bang ! Le Jeu de Dés",{"type":7,"value":8,"toc":184},"minimal",[9,16,31,45,50,57,89,96,124,128,135,145,149],[10,11,12],"p",{},[13,14,15],"strong",{},"Bang! Le Jeu de Dés — Tirez les dés… et survivez au Far West !",[10,17,18,19,22,23,26,27,30],{},"Dans ",[13,20,21],{},"Bang! Le Jeu de Dés",", incarnez un shérif, un adjoint, un hors-la-loi ou un renégat… mais ",[13,24,25],{},"sans jamais révéler votre rôle"," ! Bluffez, coopérez (ou trahissez), et ",[13,28,29],{},"utilisez les dés pour tirer, guérir ou faire exploser la dynamite"," !",[10,32,33,34,37,38,41,42,30],{},"Un jeu d’ambiance ",[13,35,36],{},"rapide, fun et tendu",", pour ",[13,39,40],{},"3 à 8 joueurs",", en ",[13,43,44],{},"15 minutes de fusillade déchaînée",[46,47,49],"h3",{"id":48},"des-rôles-secrets-et-des-flingues-bien-visibles","Des rôles secrets… et des flingues bien visibles !",[10,51,52,53,56],{},"Chaque joueur a un ",[13,54,55],{},"rôle secret"," :",[58,59,60,68,75,82],"ul",{},[61,62,63,64,67],"li",{},"👮‍♂️ Le ",[13,65,66],{},"Shérif"," (visible !) doit survivre.",[61,69,70,71,74],{},"🤠 Les ",[13,72,73],{},"Adjoints"," doivent le protéger.",[61,76,77,78,81],{},"🤬 Les ",[13,79,80],{},"Hors-la-loi"," veulent le descendre.",[61,83,84,85,88],{},"🕵️‍♂️ Le ",[13,86,87],{},"Renégat"," veut être le dernier survivant… après avoir éliminé tout le monde.",[10,90,91,92,95],{},"Et tout ce beau monde va ",[13,93,94],{},"lancer 5 dés à son tour"," pour tenter :",[58,97,98,105,111,117],{},[61,99,100,101,104],{},"De ",[13,102,103],{},"tirer"," sur ses voisins,",[61,106,100,107,110],{},[13,108,109],{},"soigner"," ses blessures,",[61,112,100,113,116],{},[13,114,115],{},"faire exploser la dynamite",",",[61,118,119,120,123],{},"Ou de ",[13,121,122],{},"déclencher des flèches"," qui viendront d’un danger commun… les Indiens 🌵🏹",[46,125,127],{"id":126},"bluff-alliances-et-coups-fourrés","Bluff, alliances et coups fourrés",[10,129,130,131,134],{},"Personne ne connaît le rôle des autres (sauf celui du Shérif) ! Alors à chaque action, ",[13,132,133],{},"on s’observe, on doute, on accuse… et parfois on se plante complètement",".",[10,136,137,138,141,142,30],{},"Un jeu où ",[13,139,140],{},"la paranoïa monte aussi vite que les blessures",", et où ",[13,143,144],{},"tout peut basculer en un jet de dés bien chanceux",[46,146,148],{"id":147},"bang-le-jeu-de-dés-cest-aussi","Bang! Le Jeu de Dés, c’est aussi :",[58,150,151,161,167,172,178],{},[61,152,153,154,157,158],{},"Une version ",[13,155,156],{},"plus rapide et plus nerveuse"," du célèbre jeu ",[13,159,160],{},"Bang!",[61,162,163,166],{},[13,164,165],{},"Des règles simples",", pour des parties immédiatement accessibles.",[61,168,169,134],{},[13,170,171],{},"Un équilibre subtil entre hasard et stratégie",[61,173,174,177],{},[13,175,176],{},"Un format compact",", parfait à emmener partout.",[61,179,180,183],{},[13,181,182],{},"Des personnages avec des pouvoirs spéciaux",", pour varier les plaisirs à chaque partie.",{"title":185,"searchDepth":186,"depth":186,"links":187},"",2,[188,190,191],{"id":48,"depth":189,"text":49},3,{"id":126,"depth":189,"text":127},{"id":147,"depth":189,"text":148},true,"md","/ludotheque/bang-le-jeu-de-des.webp",{},null,"/ludotheque/bang-le-jeu-de-des",15,{"max":200,"min":189},8,"[object Object]","ludotheque/bang-le-jeu-de-des","https://www.youtube.com/watch?v=pZfe7FGo_Og","XWswgYoml2EOdhfhmhOAQVI8vf7y8UEDTSfBhkyGB-c",1744556566411]