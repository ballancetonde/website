in":81,"max":309},"ludotheque/skull-king","https://www.youtube.com/watch?v=S5C8ifEsbzk","MXJjtduA5jX5mD6dFla7y32E8nSBVdL4cEGekrWkeBs",{"id":386,"title":387,"body":388,"description":517,"donation":90,"extension":91,"image":518,"meta":519,"navigation":94,"path":520,"play_time_mins":521,"players":522,"purchase_date":94,"seo":98,"stem":523,"video":524,"__hash__":525},"games/ludotheque/terraforming-mars.md","Terraforming Mars",{"type":8,"value":389,"toc":510},[390,395,398,404,410,413,416,433,436,442,453,456,464,467,473,480,483,486,500],[11,391,393],{"id":392},"terraforming-mars",[111,394,387],{},[16,396,397],{},"Un jeu stratégique de développement dans un univers de science-fiction où vous transformez la planète rouge !",[16,399,400,401,403],{},"Dans ",[234,402,387],{},", vous incarnez une corporation chargée de rendre Mars habitable. Gérez vos ressources, développez vos projets, et participez à la grande œuvre de transformation planétaire. À vous de faire les bons choix pour dominer vos rivaux... et faire de Mars un nouveau foyer pour l’humanité.",[20,405,407],{"id":406},"le-futur-se-construit-aujourdhui",[111,408,409],{},"Le futur se construit aujourd’hui",[16,411,412],{},"Chaque joueur développe sa propre stratégie à travers des projets variés : construction de villes, plantation de forêts, mise en place d’industries, gestion d’énergie, importation d’animaux… Les possibilités sont nombreuses et les combinaisons presque infinies.",[16,414,415],{},"La partie se déroule en plusieurs générations, durant lesquelles vous jouez des cartes projets, améliorez vos productions, et faites progresser trois grands axes de terraformation :",[61,417,418,423,428],{},[64,419,420,166],{},[111,421,422],{},"Température",[64,424,425,166],{},[111,426,427],{},"Taux d’oxygène",[64,429,430],{},[111,431,432],{},"Océans.",[16,434,435],{},"Ces trois paramètres, une fois atteints, déclenchent la fin de la partie.",[20,437,439],{"id":438},"conditions-de-victoire",[111,440,441],{},"Conditions de victoire",[16,443,444,445,448,449,452],{},"🪐 ",[111,446,447],{},"Objectif commun"," : contribuer à la terraformation de Mars. Mais seul ",[111,450,451],{},"le joueur avec le plus de points de victoire"," remportera la partie !",[16,454,455],{},"Les points sont obtenus grâce :",[61,457,458,461],{},[64,459,460],{},"Aux projets réalisés,",[64,462,463],{},"Aux récompenses et objectifs,",[16,465,466],{},"À votre influence sur la planète (villes, forêts, etc.).",[20,468,470],{"id":469},"terraforming-mars-cest-aussi",[111,471,472],{},"Terraforming Mars, c’est aussi :",[16,474,475,476,479],{},"Un jeu pour ",[111,477,478],{},"1 à 5 joueurs"," (oui, un mode solo !)",[16,481,482],{},"Une profondeur stratégique énorme à chaque partie.",[16,484,485],{},"Une grande rejouabilité avec plus de 200 cartes projets uniques.",[16,487,488,489,492,493,496,497,184],{},"Plusieurs extensions qui enrichissent le jeu de base : ",[234,490,491],{},"Venus Next, Prélude, Colonies, Turmoil",", et même une version ",[111,494,495],{},"jeu de plateau coopératif en solo ou à plusieurs"," : ",[234,498,499],{},"Ares Expedition",[16,501,502,503,506,507,184],{},"Des parties de ",[111,504,505],{},"90 à 120 minutes",", à partir de ",[111,508,509],{},"12 ans",{"title":80,"searchDepth":81,"depth":81,"links":511},[512],{"id":392,"depth":81,"text":387,"children":513},[514,515,516],{"id":406,"depth":86,"text":409},{"id":438,"depth":86,"text":441},{"id":469,"depth":86,"text":472},"Un jeu stratégique de développement dans un univers de science-fiction","/ludotheque/terraforming-mars.jpg",{},"/ludotheque/terraforming-mars",90,{"min":308,"max":352},"ludotheque/terraforming-mars","https://www.youtube.com/watch?v=r0EwRhyicyo","77TOsZRs6j-0omoef9-ILAHgQ2Q_2bj8MtkJp-mUyuA",{"id":527,"title":528,"body":529,"description":80,"donation":90,"extension":91,"image":533,"meta":534,"navigation":94,"path":535,"play_time_mins":276,"players":536,"purchase_date":94,"seo":98,"stem":537,"video":538,"__hash__":539},"games/ludotheque/trio.m