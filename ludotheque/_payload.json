":214},[],{"title":80,"searchDepth":81,"depth":81,"links":215},[],"/ludotheque/skull-king.webp",{},"/ludotheque/skull-king",{"min":81,"max":146},"ludotheque/skull-king","https://www.youtube.com/watch?v=S5C8ifEsbzk","MXJjtduA5jX5mD6dFla7y32E8nSBVdL4cEGekrWkeBs",{"id":224,"title":225,"body":226,"description":359,"donation":90,"extension":91,"image":360,"meta":361,"navigation":94,"path":362,"play_time_mins":363,"players":364,"purchase_date":94,"seo":98,"stem":365,"video":366,"__hash__":367},"games/ludotheque/terraforming-mars.md","Terraforming Mars",{"type":8,"value":227,"toc":352},[228,234,237,244,250,253,256,274,277,283,294,297,305,308,314,321,324,327,342],[11,229,231],{"id":230},"terraforming-mars",[232,233,225],"strong",{},[16,235,236],{},"Un jeu stratégique de développement dans un univers de science-fiction où vous transformez la planète rouge !",[16,238,239,240,243],{},"Dans ",[241,242,225],"em",{},", vous incarnez une corporation chargée de rendre Mars habitable. Gérez vos ressources, développez vos projets, et participez à la grande œuvre de transformation planétaire. À vous de faire les bons choix pour dominer vos rivaux... et faire de Mars un nouveau foyer pour l’humanité.",[20,245,247],{"id":246},"le-futur-se-construit-aujourdhui",[232,248,249],{},"Le futur se construit aujourd’hui",[16,251,252],{},"Chaque joueur développe sa propre stratégie à travers des projets variés : construction de villes, plantation de forêts, mise en place d’industries, gestion d’énergie, importation d’animaux… Les possibilités sont nombreuses et les combinaisons presque infinies.",[16,254,255],{},"La partie se déroule en plusieurs générations, durant lesquelles vous jouez des cartes projets, améliorez vos productions, et faites progresser trois grands axes de terraformation :",[61,257,258,264,269],{},[64,259,260,263],{},[232,261,262],{},"Température",",",[64,265,266,263],{},[232,267,268],{},"Taux d’oxygène",[64,270,271],{},[232,272,273],{},"Océans.",[16,275,276],{},"Ces trois paramètres, une fois atteints, déclenchent la fin de la partie.",[20,278,280],{"id":279},"conditions-de-victoire",[232,281,282],{},"Conditions de victoire",[16,284,285,286,289,290,293],{},"🪐 ",[232,287,288],{},"Objectif commun"," : contribuer à la terraformation de Mars. Mais seul ",[232,291,292],{},"le joueur avec le plus de points de victoire"," remportera la partie !",[16,295,296],{},"Les points sont obtenus grâce :",[61,298,299,302],{},[64,300,301],{},"Aux projets réalisés,",[64,303,304],{},"Aux récompenses et objectifs,",[16,306,307],{},"À votre influence sur la planète (villes, forêts, etc.).",[20,309,311],{"id":310},"terraforming-mars-cest-aussi",[232,312,313],{},"Terraforming Mars, c’est aussi :",[16,315,316,317,320],{},"Un jeu pour ",[232,318,319],{},"1 à 5 joueurs"," (oui, un mode solo !)",[16,322,323],{},"Une profondeur stratégique énorme à chaque partie.",[16,325,326],{},"Une grande rejouabilité avec plus de 200 cartes projets uniques.",[16,328,329,330,333,334,337,338,341],{},"Plusieurs extensions qui enrichissent le jeu de base : ",[241,331,332],{},"Venus Next, Prélude, Colonies, Turmoil",", et même une version ",[232,335,336],{},"jeu de plateau coopératif en solo ou à plusieurs"," : ",[241,339,340],{},"Ares Expedition",".",[16,343,344,345,348,349,341],{},"Des parties de ",[232,346,347],{},"90 à 120 minutes",", à partir de ",[232,350,351],{},"12 ans",{"title":80,"searchDepth":81,"depth":81,"links":353},[354],{"id":230,"depth":81,"text":225,"children":355},[356,357,358],{"id":246,"depth":86,"text":249},{"id":279,"depth":86,"text":282},{"id":310,"depth":86,"text":313},"Un jeu stratégique de développement dans un univers de science-fiction","/ludotheque/terraforming-mars.jpg",{},"/ludotheque/terraforming-mars",90,{"min":145,"max":190},"ludotheque/terraforming-mars","https://www.youtube.com/watch?v=r0EwRhyicyo","77TOsZRs6j-0omoef9-ILAHgQ2Q_2bj8MtkJp-mUyuA",{"id":369,"title":370,"body":371,"description":80,"donation":90,"extension":91,"image":375,"meta":376,"nav