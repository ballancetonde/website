[{"data":1,"prerenderedAt":163},["ShallowReactive",2],{"/ludotheque/photosynthesis":3},{"id":4,"title":5,"body":6,"description":149,"donation":150,"extension":151,"image":152,"meta":153,"navigation":154,"path":155,"play_time_mins":156,"players":157,"purchase_date":154,"seo":159,"stem":160,"video":161,"__hash__":162},"games/ludotheque/Photosynthesis.md","Photosynthesis",{"type":7,"value":8,"toc":142},"minimal",[9,17,44,58,63,87,94,98],[10,11,13],"h1",{"id":12},"photosynthesis-la-lumière-est-votre-ressource-la-forêt-votre-terrain-de-jeu",[14,15,16],"strong",{},"Photosynthesis — La lumière est votre ressource, la forêt votre terrain de jeu.",[18,19,20,21,23,24,27,28,31,32,35,36,39,40,43],"p",{},"Dans ",[14,22,5],{},", vous incarnez une essence d’arbre et luttez pour ",[14,25,26],{},"faire croître votre forêt"," en ",[14,29,30],{},"captant l’énergie du soleil",". Un jeu ",[14,33,34],{},"éblouissant de beauté"," et ",[14,37,38],{},"profondément tactique",", où il faut ",[14,41,42],{},"planter, grandir, et ombrager vos adversaires"," pour prospérer.",[18,45,46,47,50,51,54,55],{},"Pour ",[14,48,49],{},"2 à 4 joueurs",", dès ",[14,52,53],{},"10 ans",", en ",[14,56,57],{},"30 à 60 minutes de stratégie lumineuse.",[59,60,62],"h3",{"id":61},"lart-de-pousser-à-lombre-des-autres","L’art de pousser… à l’ombre des autres",[64,65,66,74,81],"ol",{},[67,68,69,70,73],"li",{},"Placez vos graines, faites pousser vos arbres et ",[14,71,72],{},"collectez des points selon l’âge et l’emplacement"," de vos arbres.",[67,75,76,77,80],{},"Le soleil tourne autour du plateau : ",[14,78,79],{},"plus vos arbres sont exposés, plus vous gagnez de lumière",".",[67,82,83,84,80],{},"Utilisez cette lumière comme monnaie pour ",[14,85,86],{},"planter de nouveaux arbres ou faire grandir ceux déjà présents",[18,88,89,90,93],{},"🌞 Mais attention, vos arbres peuvent ",[14,91,92],{},"projeter de l’ombre sur les autres… et sur vous-même"," !",[59,95,97],{"id":96},"photosynthesis-cest-aussi","Photosynthesis, c’est aussi :",[99,100,101,112,119,130,136],"ul",{},[67,102,103,104,107,108,111],{},"Un jeu ",[14,105,106],{},"sans hasard",", où seule ",[14,109,110],{},"la planification et l’anticipation"," comptent.",[67,113,114,115,118],{},"Une ",[14,116,117],{},"expérience zen mais compétitive",", où chaque décision a un impact.",[67,120,121,122,125,126,129],{},"Un ",[14,123,124],{},"matériel somptueux",", avec de ",[14,127,128],{},"vrais arbres en 3D"," à poser sur le plateau.",[67,131,103,132,135],{},[14,133,134],{},"écologique dans l’âme",", aussi plaisant à jouer qu’à contempler.",[67,137,114,138,141],{},[14,139,140],{},"extension \"Under the Moonlight\""," pour encore plus de profondeur stratégique.",{"title":143,"searchDepth":144,"depth":144,"links":145},"",2,[146,148],{"id":61,"depth":147,"text":62},3,{"id":96,"depth":147,"text":97},"Dans Photosynthesis, vous incarnez une essence d’arbre et luttez pour faire croître votre forêt en captant l’énergie du soleil. Un jeu éblouissant de beauté et profondément tactique, où il faut planter, grandir, et ombrager vos adversaires pour prospérer.",true,"md","/ludotheque/photosynthesis.webp",{},null,"/ludotheque/photosynthesis",45,{"min":144,"max":158},4,"[object Object]","ludotheque/Photosynthesis","https://www.youtube.com/watch?v=x0H4n28UoQE","1NJk-swOCKBZkZ76-G_lMGDwvd8M261mS97wk4PLwQI",1745021915871]