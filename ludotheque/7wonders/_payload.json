[{"data":1,"prerenderedAt":200},["ShallowReactive",2],{"/ludotheque/7wonders":3},{"id":4,"title":5,"body":6,"description":186,"donation":187,"extension":188,"image":189,"meta":190,"navigation":191,"path":192,"play_time_mins":193,"players":194,"purchase_date":191,"seo":196,"stem":197,"video":198,"__hash__":199},"games/ludotheque/7wonders.md","7wonders",{"type":7,"value":8,"toc":178},"minimal",[9,17,37,48,53,60,73,82,86,93,128,134,138],[10,11,13],"h1",{"id":12},"_7-wonders-bâtissez-une-civilisation-dominez-lhistoire",[14,15,16],"strong",{},"7 Wonders — Bâtissez une civilisation. Dominez l’Histoire.",[18,19,20,21,24,25,28,29,32,33,36],"p",{},"Dans ",[14,22,23],{},"7 Wonders",", vous prenez les rênes d’une cité antique en pleine expansion. ",[14,26,27],{},"Commerce, science, armée, merveilles architecturales","… Choisissez vos cartes avec soin et construisez ",[14,30,31],{},"la plus glorieuse des civilisations"," en seulement ",[14,34,35],{},"30 minutes",".",[18,38,39,40,43,44,47],{},"Un jeu stratégique ",[14,41,42],{},"rapide, fluide et terriblement addictif",", pour ",[14,45,46],{},"3 à 7 joueurs",", sans temps mort.",[49,50,52],"h3",{"id":51},"une-partie-en-trois-âges-et-des-choix-décisifs","Une partie en trois Âges… et des choix décisifs",[18,54,55,56,59],{},"La partie se déroule en ",[14,57,58],{},"trois Âges",". À chaque tour :",[61,62,63,67,70],"ol",{},[64,65,66],"li",{},"Vous choisissez une carte de votre main.",[64,68,69],{},"Vous jouez cette carte pour développer votre cité : ressources, armée, science, commerce, ou merveilles.",[64,71,72],{},"Vous passez le reste de votre main au voisin.",[18,74,75,78,79,36],{},[14,76,77],{},"Draft, anticipation et interaction"," sont au cœur du jeu. Chaque carte choisie est une opportunité… mais aussi une carte que vous ",[14,80,81],{},"laissez à un adversaire",[49,83,85],{"id":84},"plusieurs-voies-vers-la-victoire","Plusieurs voies vers la victoire",[18,87,88,89,92],{},"À la fin de la partie, les joueurs comptent leurs ",[1