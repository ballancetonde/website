[{"data":1,"prerenderedAt":146},["ShallowReactive",2],{"/ludotheque/code-name":3},{"id":4,"title":5,"body":6,"description":15,"donation":133,"extension":134,"image":135,"meta":136,"navigation":137,"path":138,"play_time_mins":139,"players":140,"purchase_date":137,"seo":142,"stem":143,"video":144,"__hash__":145},"games/ludotheque/code-name.md","Code Name",{"type":7,"value":8,"toc":124},"minimal",[9,16,23,26,31,46,50,57,61,83,87],[10,11,12],"p",{},[13,14,15],"strong",{},"Code Name — Un jeu d’espionnage haletant à deux ou en équipe !",[10,17,18,19,22],{},"Deux maîtres-espions, une mission secrète : ",[13,20,21],{},"faire deviner à leur équipe les bons noms de code"," dissimulés parmi une grille de 25 mots. Mais attention : une seule erreur, et c’est peut-être l’assassin que vous venez de dévoiler…",[10,24,25],{},"Code Name, c’est un jeu d’association d’idées, de logique… et de nerfs solides !",[27,28,30],"h3",{"id":29},"un-duel-desprit-et-de-déduction","Un duel d’esprit et de déduction",[10,32,33,34,37,38,41,42,45],{},"Code Name peut se jouer en ",[13,35,36],{},"mode compétitif à 2 équipes",", ou en ",[13,39,40],{},"coopération à deux joueurs",". Chaque tour, un maître-espion donne ",[13,43,44],{},"un mot et un chiffre"," pour guider ses agents vers les bons mots, mais sans tomber sur ceux de l’équipe adverse… ou pire, sur l’assassin.",[27,47,49],{"id":48},"le-but-du-jeu","Le but du jeu ?",[10,51,52,53,56],{},"Devinez tous les mots associés à votre couleur ",[13,54,55],{},"avant l’autre équipe",", ou avant la fin des tentatives en mode coop.",[27,58,60],{"id":59},"mais-attention","Mais attention…",[62,63,64,71,77],"ul",{},[65,66,67,70],"li",{},[13,68,69],{},"Les mots neutres"," ne vous aident pas.",[65,72,73,76],{},[13,74,75],{},"Les mots adverses"," aident l’ennemi.",[65,78,79,82],{},[13,80,81],{},"L’assassin ?"," Il met fin à la partie immédiatement. Une erreur fatale.",[27,84,86],{"id":85},"code-name-cest-aussi","Code Name, c’est aussi :",[62,88,89,95,101,107,118],{},[65,90,91,94],{},[13,92,93],{},"Un jeu rapide et malin",", accessible en quelques minutes, mais toujours surprenant.",[65,96,97,100],{},[13,98,99],{},"Des milliers de combinaisons possibles",", pour une rejouabilité quasi infinie.",[65,102,103,106],{},[13,104,105],{},"Un excellent jeu d’ambiance",", aussi fun entre amis qu’en famille ou en couple.",[65,108,109,112,113,117],{},[13,110,111],{},"Une version duo coopérative"," spécialement pensée pour deux joueurs : ",[114,115,116],"em",{},"Codenames Duo",".",[65,119,120,123],{},[13,121,122],{},"Des versions thématiques"," (Marvel, Disney, Images…) pour tous les publics.",{"title":125,"searchDepth":126,"depth":126,"links":127},"",2,[128,130,131,132],{"id":29,"depth":129,"text":30},3,{"id":48,"depth":129,"text":49},{"id":59,"depth":129,"text":60},{"id":85,"depth":129,"text":86},false,"md","/ludotheque/code-name.webp",{},null,"/ludotheque/code-name",15,{"min":126,"max":141},8,"[object Object]","ludotheque/code-name","https://www.youtube.com/watch?v=Bi5q9YuCEQw","R8EHhOcaWMXWManQes6PewKygsR4Tc4cWXYxQByqtMI",1744555443573]