[{"data":1,"prerenderedAt":199},["ShallowReactive",2],{"/ludotheque/the-game-extreme":3},{"id":4,"title":5,"body":6,"description":184,"donation":185,"extension":186,"image":187,"meta":188,"navigation":189,"path":190,"play_time_mins":191,"players":192,"purchase_date":189,"seo":195,"stem":196,"video":197,"__hash__":198},"games/ludotheque/the-game-extreme.md","The Game Extrême",{"type":7,"value":8,"toc":176},"minimal",[9,17,32,42,57,62,69,79,82,88,98,126,130,140,144],[10,11,13],"h1",{"id":12},"the-game-extrême-un-seul-but-survivre-ensemble-malgré-les-règles",[14,15,16],"strong",{},"The Game Extrême — Un seul but : survivre ensemble… malgré les règles.",[18,19,20,21,23,24,27,28,31],"p",{},"Dans ",[14,22,5],{},", vous êtes tous dans le même camp. Le but ? ",[14,25,26],{},"Vaincre le jeu"," en posant ",[14,29,30],{},"toutes les cartes"," de la pioche… dans l’ordre croissant ou décroissant sur deux piles.",[18,33,34,35,38,39],{},"Mais attention : ",[14,36,37],{},"le jeu se défend."," Il vous impose des règles spéciales, vous empêche de communiquer librement, et ",[14,40,41],{},"ne vous pardonne aucune erreur.",[18,43,44,45,48,49,52,53,56],{},"Un jeu coopératif ",[14,46,47],{},"simple à expliquer, mais diabolique à battre",", pour ",[14,50,51],{},"1 à 5 joueurs",", en ",[14,54,55],{},"20 minutes de tension pure",".",[58,59,61],"h3",{"id":60},"des-règles-simples-une-tension-constante","Des règles simples, une tension constante",[18,63,64,65,68],{},"Vous avez des cartes numérotées de 1 à 100. À chaque tour, vous ",[14,66,67],{},"devez jouer deux cartes minimum"," sur l’une des quatre piles :",[70,71,72,76],"ul",{},[73,74,75],"li",{},"Deux piles en ordre croissant.",[73,77,78],{},"Deux piles en ordre décroissant.",[18,80,81],{},"Et c’est tout… ou presque.",[18,83,84,87],{},[14,85,86],{},"La seule échappatoire ?"," Jouer exactement 10 de plus ou 10 de moins pour \"remonter le temps\" et créer de l’espace.",[18,89,90,91,93,94,97],{},"Mais dans ",[14,92,5],{},", des ",[14,95,96],{},"cartes spéciales apparaissent",", comme :",[70,99,100,106,112],{},[73,101,102,105],{},[14,103,104],{},"Silence total"," : plus le droit de parler.",[73,107,108,111],{},[14,109,110],{},"Ordre obligatoire"," : tout le monde doit jouer dans un sens précis.",[73,113,114,117,118,121,122,125],{},[14,115,116],{},"Cartes prioritaires",", ",[14,119,120],{},"interdictions de pile"," ou encore ",[14,123,124],{},"chaînes de jeu forcées","…",[58,127,129],{"id":128},"un-défi-collectif-une-lutte-contre-le-chaos","Un défi collectif, une lutte contre le chaos",[18,131,132,133,136,137],{},"Il faudra ",[14,134,135],{},"lire les intentions des autres joueurs",", anticiper, et parfois sacrifier ses meilleures cartes. Le jeu vous pousse à bout. La moindre erreur peut coûter la victoire. ",[14,138,139],{},"Vous n’êtes pas là pour gagner souvent. Mais pour tenter. Et retenter.",[58,141,143],{"id":142},"the-game-extrême-cest-aussi","The Game Extrême, c’est aussi :",[70,145,146,152,158,164,170],{},[73,147,148,151],{},[14,149,150],{},"Un jeu coopératif minimaliste",", mais redoutablement addictif.",[73,153,154,157],{},[14,155,156],{},"Une montée en tension immédiate",", dès les premières cartes.",[73,159,160,163],{},[14,161,162],{},"Un format parfait à emporter",", à sortir n’importe où.",[73,165,166,169],{},[14,167,168],{},"Une rejouabilité folle",", car chaque partie est unique et chaque erreur, différente.",[73,171,172,175],{},[14,173,174],{},"Une version solo"," tout aussi captivante qu’à plusieurs.",{"title":177,"searchDepth":178,"depth":178,"links":179},"",2,[180,182,183],{"id":60,"depth":181,"text":61},3,{"id":128,"depth":181,"text":129},{"id":142,"depth":181,"text":143},"Dans The Game Extrême, vous êtes tous dans le même camp. Le but ? Vaincre le jeu en posant toutes les cartes de la pioche… dans l’ordre croissant ou décroissant sur deux piles.",true,"md","/ludotheque/the-game-extreme.webp",{},null,"/ludotheque/the-game-extreme",20,{"min":193,"max":194},1,5,"[object Object]","ludotheque/the-game-extreme","https://www.youtube.com/watch?v=JmyCPwJKMr4","SmO1VwP6ObPcbA4P1lRxmtYlVQnRKnz7Y3TZExkx7lE",1744551247812]