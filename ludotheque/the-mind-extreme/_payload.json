[{"data":1,"prerenderedAt":195},["ShallowReactive",2],{"/ludotheque/the-mind-extreme":3},{"id":4,"title":5,"body":6,"description":181,"donation":182,"extension":183,"image":184,"meta":185,"navigation":186,"path":187,"play_time_mins":188,"players":189,"purchase_date":186,"seo":191,"stem":192,"video":193,"__hash__":194},"games/ludotheque/The-Mind-Extreme.md","The Mind Extrême",{"type":7,"value":8,"toc":173},"minimal",[9,17,47,65,70,100,107,111,130,134],[10,11,13],"h1",{"id":12},"the-mind-extrême-quand-la-télépathie-devient-un-sport-de-lextrême",[14,15,16],"strong",{},"The Mind Extrême — Quand la télépathie devient un sport de l’extrême.",[18,19,20,21,24,25,28,29,31,32,35,36,35,39,42,43,46],"p",{},"Vous avez adoré ",[14,22,23],{},"The Mind"," ? Préparez-vous à aller ",[14,26,27],{},"encore plus loin, plus vite… et dans le noir."," Dans ",[14,30,5],{},", la communication est toujours interdite. Mais cette fois, ",[14,33,34],{},"vous jouez sur DEUX piles simultanément",", parfois ",[14,37,38],{},"à l’envers",[14,40,41],{},"dans le silence total."," Un jeu de coordination mentale ",[14,44,45],{},"poussé à son paroxysme",".",[18,48,49,50,53,54,57,58,61,62,46],{},"Un jeu ",[14,51,52],{},"coopératif, minimaliste et intense",", pour ",[14,55,56],{},"2 à 4 joueurs",", dès ",[14,59,60],{},"10 ans",", en ",[14,63,64],{},"20 minutes de pur stress zen",[66,67,69],"h3",{"id":68},"une-connexion-mentale-ou-le-chaos-total","Une connexion mentale… ou le chaos total",[71,72,73,80],"ol",{},[74,75,76,77,46],"li",{},"Chacun reçoit des cartes numérotées de ",[14,78,79],{},"1 à 50",[74,81,82,83,86,87],{},"En silence, ",[14,84,85],{},"vous devez les jouer dans le bon ordre",", sur deux piles :\n",[88,89,90,95],"ul",{},[74,91,92],{},[14,93,94],{},"Une en ordre croissant",[74,96,97],{},[14,98,99],{},"L’autre en ordre décroissant",[18,101,102,103,106],{},"Et parfois, l’une des deux piles est ",[14,104,105],{},"jouée à l’aveugle",", sans voir les cartes posées. 😱 Vous sentez la pression monter ?",[66,108,110],{"id":109},"un-défi-de-groupe-un-vrai-test-de-feeling","Un défi de groupe, un vrai test de feeling",[18,112,113,114,117,118,121,122,125,126,129],{},"Aucun tour, aucune parole, aucun signal autorisé. Vous ne pouvez compter que sur ",[14,115,116],{},"le timing",", ",[14,119,120],{},"les intuitions",", et ",[14,123,124],{},"l’harmonie mentale du groupe",". Plus vous progressez dans les niveaux, ",[14,127,128],{},"plus la tension devient palpitante",". Jusqu’à l’explosion… ou la victoire.",[66,131,133],{"id":132},"the-mind-extrême-cest-aussi","The Mind Extrême, c’est aussi :",[88,135,136,147,157,167],{},[74,137,138,139,142,143,146],{},"Une expérience ",[14,140,141],{},"sensorielle et collective",", qui ",[14,144,145],{},"renforce la complicité"," entre joueurs.",[74,148,149,152,153,156],{},[14,150,151],{},"Une mécanique ultra simple",", mais ",[14,154,155],{},"des sensations uniques"," à chaque partie.",[74,158,159,160,163,164,46],{},"Des parties ",[14,161,162],{},"courtes, rejouables",", qui deviennent vite ",[14,165,166],{},"addictives",[74,168,169,170],{},"Le jeu parfait pour ceux qui aiment ",[14,171,172],{},"les émotions fortes sans un mot.",{"title":174,"searchDepth":175,"depth":175,"links":176},"",2,[177,179,180],{"id":68,"depth":178,"text":69},3,{"id":109,"depth":178,"text":110},{"id":132,"depth":178,"text":133},"Vous avez adoré The Mind ? Préparez-vous à aller encore plus loin, plus vite… et dans le noir. Dans The Mind Extrême, la communication est toujours interdite. Mais cette fois, vous jouez sur DEUX piles simultanément, parfois à l’envers, parfois dans le silence total. Un jeu de coordination mentale poussé à son paroxysme.",true,"md","/ludotheque/the-mind-extreme.webp",{},null,"/ludotheque/the-mind-extreme",20,{"min":175,"max":190},4,"[object Object]","ludotheque/The-Mind-Extreme","https://www.youtube.com/watch?v=QvEfUdi3vo4","GlU3nQdbD_XybCoxSSsI4__iEzDuniJ4mPd4ZMEIloM",1744556458297]