[{"data":1,"prerenderedAt":152},["ShallowReactive",2],{"/ludotheque/little-town":3},{"id":4,"title":5,"body":6,"description":138,"donation":139,"extension":140,"image":141,"meta":142,"navigation":143,"path":144,"play_time_mins":145,"players":146,"purchase_date":143,"seo":148,"stem":149,"video":150,"__hash__":151},"games/ludotheque/Little-Town.md","Little Town",{"type":7,"value":8,"toc":129},"minimal",[9,17,25,28,31,56,63,67,78,82],[10,11,13,16],"h3",{"id":12},"little-town-un-jeu-de-stratégie-accessible-et-diablement-malin",[14,15,5],"strong",{},", un jeu de stratégie accessible… et diablement malin !",[18,19,20,21,24],"p",{},"Bienvenue dans la vallée fertile de Little Town, où tout est à construire ! Exploitez les ressources, bâtissez des bâtiments et développez une ville prospère pour devenir ",[14,22,23],{},"le meilleur architecte"," !",[18,26,27],{},"Un subtil mélange de placement et de gestion",[18,29,30],{},"À chaque tour, vous avez deux options :",[32,33,34,49],"ul",{},[35,36,37,40,41,44,45,48],"li",{},[14,38,39],{},"Placer un ouvrier"," sur le plateau pour récolter ",[14,42,43],{},"les ressources voisines"," (bois, pierre, poisson, blé…) et ",[14,46,47],{},"activer des bâtiments"," (même ceux des autres !),",[35,50,51,52,55],{},"Ou ",[14,53,54],{},"construire un bâtiment",", en dépensant les ressources nécessaires.",[18,57,58,59,62],{},"Les bâtiments rapportent ",[14,60,61],{},"des points de victoire"," et offrent des effets utiles pour le reste de la partie. Mais attention à bien gérer votre nourriture : à la fin de chaque manche, il faut nourrir ses ouvriers !",[10,64,66],{"id":65},"victoire-par-développement","Victoire par développement",[18,68,69,70,73,74,77],{},"🧱 Chaque bâtiment construit et chaque objectif accompli rapporte ",[14,71,72],{},"des points",". 🍞 Une bonne gestion de vos ressources et de votre placement fait toute la différence. 🎯 À la fin des 4 manches, le joueur avec le ",[14,75,76],{},"plus de points de victoire"," l’emporte !",[10,79,81],{"id":80},"little-town-cest-aussi","Little Town, c’est aussi :",[32,83,84,99,109,116,123],{},[35,85,86,87,90,91,94,95,98],{},"Un jeu ",[14,88,89],{},"de placement et de construction",", pour ",[14,92,93],{},"2 à 4 joueurs",", à partir de ",[14,96,97],{},"10 ans",".",[35,100,101,102,105,106,98],{},"Des ",[14,103,104],{},"règles simples",", mais une grande ",[14,107,108],{},"profondeur stratégique",[35,110,111,112,115],{},"Un matériel clair et coloré, parfait pour ",[14,113,114],{},"initier à la stratégie"," sans complexité.",[35,117,118,119,122],{},"Une ",[14,120,121],{},"grande interaction"," grâce à l’activation des bâtiments adverses et le placement malin.",[35,124,101,125,128],{},[14,126,127],{},"parties rapides et tendues"," (environ 30 à 45 minutes), toujours renouvelées grâce à la variété des bâtiments.",{"title":130,"searchDepth":131,"depth":131,"links":132},"",2,[133,136,137],{"id":12,"depth":134,"text":135},3,"Little Town, un jeu de stratégie accessible… et diablement malin !",{"id":65,"depth":134,"text":66},{"id":80,"depth":134,"text":81},"Bienvenue dans la vallée fertile de Little Town, où tout est à construire !",true,"md","/ludotheque/little-town.webp",{},null,"/ludotheque/little-town",45,{"min":131,"max":147},4,"[object Object]","ludotheque/Little-Town","https://www.youtube.com/watch?v=duZkbNWCk50","r_GVp-TyVXKa2A_jVqpFLukswcKeYSLceoo0-KMjWOs",1744104127723]