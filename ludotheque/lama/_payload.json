[{"data":1,"prerenderedAt":167},["ShallowReactive",2],{"/ludotheque/lama":3},{"id":4,"title":5,"body":6,"description":146,"donation":154,"extension":155,"image":156,"meta":157,"navigation":158,"path":159,"play_time_mins":160,"players":161,"purchase_date":158,"seo":163,"stem":164,"video":165,"__hash__":166},"games/ludotheque/Lama.md","Lama",{"type":7,"value":8,"toc":145},"minimal",[9,17,29,32,39,61,72,76,87,98,102],[10,11,13,16],"h3",{"id":12},"lama-un-jeu-de-cartes-simple-rapide-et-complètement-déjanté",[14,15,5],"strong",{},", un jeu de cartes simple, rapide… et complètement déjanté !",[18,19,20,21,24,25,28],"p",{},"Débarrassez-vous de vos cartes le plus vite possible pour éviter d’accumuler des points négatifs. Mais attention : parfois, mieux vaut ",[14,22,23],{},"quitter la manche"," plutôt que de ",[14,26,27],{},"prendre le risque de trop en faire","… sauf si vous osez rester et tenter de poser ce fichu lama !",[18,30,31],{},"Le lama veille… et les points s’accumulent",[18,33,34,35,38],{},"Une partie de Lama se joue en plusieurs manches. Chaque joueur reçoit des cartes numérotées de 1 à 6, ainsi que des cartes ",[14,36,37],{},"lama"," (les pires !). À son tour, un joueur peut :",[40,41,42,49,55],"ul",{},[43,44,45,48],"li",{},[14,46,47],{},"Jouer une carte"," de même valeur ou supérieure de +1 que celle de la pile,",[43,50,51,54],{},[14,52,53],{},"Piocher une carte",",",[43,56,57,58,60],{},"Ou ",[14,59,23],{},".",[18,62,63,64,67,68,71],{},"Les cartes non posées à la fin de la manche donnent des ",[14,65,66],{},"points négatifs",". Le joueur avec ",[14,69,70],{},"le moins de points"," à la fin gagne !",[10,73,75],{"id":74},"victoire-par-prudence-ou-par-audace","Victoire par prudence… ou par audace",[18,77,78,79,82,83,86],{},"💥 Les cartes lama valent ",[14,80,81],{},"10 points négatifs"," ! 😬 Les points ne se ",[14,84,85],{},"comptent qu’une seule fois"," par valeur : deux cartes \"3\" valent quand même seulement -3 points.",[18,88,89,90,93,94,97],{},"🎯 Dès qu’un joueur atteint ",[14,91,92],{},"40 points",", la partie se termine. Celui qui en a le ",[14,95,96],{},"moins"," l’emporte !",[10,99,101],{"id":100},"lama-cest-aussi","Lama, c’est aussi :",[40,103,104,118,125,132,138],{},[43,105,106,107,110,111,114,115,60],{},"Un jeu de cartes ",[14,108,109],{},"ultra accessible",", à partir de ",[14,112,113],{},"8 ans",", pour ",[14,116,117],{},"2 à 6 joueurs",[43,119,120,121,124],{},"Des ",[14,122,123],{},"parties rapides et dynamiques"," (10 à 20 minutes).",[43,126,127,128,131],{},"Des choix ",[14,129,130],{},"simples mais malins"," : s’accrocher ou se coucher ?",[43,133,134,135,60],{},"Une ambiance ",[14,136,137],{},"fun, pleine de bluff et de rebondissements",[43,139,140,141,144],{},"Un jeu nominé au ",[14,142,143],{},"Spiel des Jahres"," (Jeu de l’année en Allemagne) grâce à sa simplicité et son efficacité.",{"title":146,"searchDepth":147,"depth":147,"links":148},"",2,[149,152,153],{"id":12,"depth":150,"text":151},3,"Lama, un jeu de cartes simple, rapide… et complètement déjanté !",{"id":74,"depth":150,"text":75},{"id":100,"depth":150,"text":101},false,"md","/ludotheque/lama.jpg",{},null,"/ludotheque/lama",20,{"min":147,"max":162},6,"[object Object]","ludotheque/Lama","https://www.youtube.com/watch?v=NoOQ7NP-OcE","CtVVplpDAPxPWrPEY-BljzxMeZdWzc63x4IHAauTKwU",1744059788037]