[{"data":1,"prerenderedAt":204},["ShallowReactive",2],{"/ludotheque/mr-jack":3},{"id":4,"title":5,"body":6,"description":192,"donation":193,"extension":194,"image":195,"meta":196,"navigation":197,"path":198,"play_time_mins":197,"players":199,"purchase_date":197,"seo":200,"stem":201,"video":202,"__hash__":203},"games/ludotheque/mr-jack.md","Mr Jack",{"type":7,"value":8,"toc":184},"minimal",[9,17,40,54,59,70,96,106,110,136,139,143],[10,11,13],"h1",{"id":12},"mr-jack-un-coupable-un-enquêteur-une-nuit-pour-découvrir-la-vérité",[14,15,16],"strong",{},"Mr Jack — Un coupable. Un enquêteur. Une nuit pour découvrir la vérité.",[18,19,20,21,23,24,27,28,31,32,35,36,39],"p",{},"Dans ",[14,22,5],{},", deux joueurs s’affrontent dans une ",[14,25,26],{},"partie de cache-cache stratégique dans les rues embrumées de Londres",". L’un incarne ",[14,29,30],{},"Jack l’Éventreur",", dissimulé parmi huit personnages. L’autre incarne ",[14,33,34],{},"l’Enquêteur",", prêt à tout pour démasquer et capturer le coupable ",[14,37,38],{},"avant la fin de la huitième manche",".",[18,41,42,43,46,47,50,51,39],{},"Un duel asymétrique ",[14,44,45],{},"fin, tendu et palpitant",", pour ",[14,48,49],{},"2 joueurs",", en ",[14,52,53],{},"30 minutes d’enquête pure",[55,56,58],"h3",{"id":57},"une-chasse-à-lhomme-en-plein-cœur-du-xixe-siècle","Une chasse à l’homme en plein cœur du XIXe siècle",[18,60,61,62,65,66,69],{},"Le jeu se déroule en ",[14,63,64],{},"8 manches maximum",". À chaque manche, les joueurs activent ",[14,67,68],{},"4 personnages"," aux capacités uniques pour :",[71,72,73,80,85,90],"ul",{},[74,75,76,79],"li",{},[14,77,78],{},"Se déplacer dans Londres",",",[74,81,82,79],{},[14,83,84],{},"Éclairer ou éteindre des réverbères",[74,86,87,79],{},[14,88,89],{},"Bloquer ou ouvrir des passages",[74,91,92,93],{},"Et surtout : ",[14,94,95],{},"observer qui est visible… et qui ne l’est pas.",[18,97,98,101,102,105],{},[14,99,100],{},"Mr Jack se cache parmi ces personnages."," L’Enquêteur doit ",[14,103,104],{},"croiser les indices et éliminer les suspects",", tour après tour.",[55,107,109],{"id":108},"dédoublez-votre-esprit-bluff-contre-déduction","Dédoublez votre esprit : bluff contre déduction",[71,111,112,125],{},[74,113,114,115,117,118,121,122],{},"En tant que ",[14,116,5],{},", votre but est de ",[14,119,120],{},"quitter le plateau","… ou de ",[14,123,124],{},"garder votre identité secrète jusqu’à la fin.",[74,126,127,128,131,132,135],{},"En tant qu’",[14,129,130],{},"Enquêteur",", vous devez ",[14,133,134],{},"révéler qui est Mr Jack","… et l’arrêter avant qu’il ne disparaisse dans l’ombre.",[18,137,138],{},"Une seule erreur de lecture peut coûter la victoire.",[55,140,142],{"id":141},"mr-jack-cest-aussi","Mr Jack, c’est aussi :",[71,144,145,151,157,163,169],{},[74,146,147,150],{},[14,148,149],{},"Un des meilleurs jeux à 2 joueurs",", signé Bruno Cathala et Ludovic Maublanc.",[74,152,153,156],{},[14,154,155],{},"Des mécaniques asymétriques ultra équilibrées",", avec des parties tendues jusqu’au bout.",[74,158,159,162],{},[14,160,161],{},"Un jeu de bluff, de logique et d’anticipation",", parfait pour les duels tactiques.",[74,164,165,168],{},[14,166,167],{},"Des personnages aux capacités variées",", pour renouveler chaque partie.",[74,170,171,174,175,179,180,183],{},[14,172,173],{},"Des extensions et variantes",", dont ",[176,177,178],"em",{},"Mr Jack à New York"," et ",[176,181,182],{},"Mr Jack Pocket",", pour plus de rejouabilité.",{"title":185,"searchDepth":186,"depth":186,"links":187},"",2,[188,190,191],{"id":57,"depth":189,"text":58},3,{"id":108,"depth":189,"text":109},{"id":141,"depth":189,"text":142},"Dans Mr Jack, deux joueurs s’affrontent dans une partie de cache-cache stratégique dans les rues embrumées de Londres. L’un incarne Jack l’Éventreur, dissimulé parmi huit personnages. L’autre incarne l’Enquêteur, prêt à tout pour démasquer et capturer le coupable avant la fin de la huitième manche.",true,"md","/ludotheque/mr-jack.webp",{},null,"/ludotheque/mr-jack",{"min":186,"max":186},"[object Object]","ludotheque/mr-jack","https://www.youtube.com/watch?v=jcdbMv1qGV0","nOtUJKM4iA5wZNIS5oxWU0V_mKqzAwf68SNT5v089O4",1744556346895]